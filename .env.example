# Copie para .env e preencha os valores.
# Nunca commite o arquivo .env com dados reais.

FLASK_ENV=development
SECRET_KEY=sua-chave-secreta-muito-segura-aqui

# Banco de dados:
# - Sem DATABASE_URL: usa SQLite (instance/opa.db) — desenvolvimento.
# - Com DATABASE_URL: usa PostgreSQL — produção.
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/observatorio_opa
